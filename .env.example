# Postgres (Supabase pooled connection string in production)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/punchlist"

# Supabase — public (browser)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Supabase — server only (photo upload to Storage; never expose to the client)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
